# ============================================
# Fit Finder — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/fitfinder

# Session (required in production)
SESSION_SECRET=generate-a-64-character-random-string

# Server
PORT=5000
NODE_ENV=development
APP_URL=http://localhost:5000

# Proxy trust — set to true in Railway (production + staging) when behind Cloudflare.
# Leave unset or false in local dev (no proxy).
TRUST_PROXY=false

# Split deployment (set these when frontend ≠ backend origin)
FRONTEND_URL=https://fitfinder.vercel.app
VITE_API_URL=https://api.fitfinder.co

# Stripe (optional — payments disabled without these)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_CLIENT_ID=ca_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Redis (optional — falls back to in-memory cache and PostgreSQL sessions without this)
# Add a Railway Redis service and copy the connection URL here.
REDIS_URL=redis://default:password@host:6379

# Cloudflare R2 (optional — falls back to base64 storage without these)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET=fitfinder-uploads
R2_PUBLIC_URL=https://uploads.fitfinder.co

# Email via Resend (optional — logs to console without this)
RESEND_API_KEY=re_...
FROM_EMAIL=Fit Finder <noreply@fitfinder.co>

# Sentry error tracking (optional — errors only logged to console without these)
# Create a project at https://sentry.io and copy the DSN from Project Settings → Client Keys.
# Use separate Sentry projects for production and staging so noise is isolated.
# VITE_SENTRY_DSN is embedded in the browser bundle (safe — DSNs are public-facing).
SENTRY_DSN=https://...@sentry.io/...
VITE_SENTRY_DSN=https://...@sentry.io/...
